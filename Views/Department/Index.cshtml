@model IEnumerable<StudentSystem.Models.Department>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">
        ➕ Add New Department
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover shadow-sm">
        <thead style="background: linear-gradient(90deg, #4e54c8, #8f94fb);">
            <tr>
                <th style="color:black; font-weight:bold; background:transparent;">ID</th>
                <th style="color:black; font-weight:bold; background:transparent;">Name</th>
                <th style="color:black; font-weight:bold; background:transparent;">Location</th>
                <th style="color:black; font-weight:bold; background:transparent;">Phone</th>
                <th style="color:black; font-weight:bold; background:transparent;">Students Count</th>
                <th style="color:black; font-weight:bold; background:transparent;" class="text-center">Actions</th>
            </tr>
        </thead>
        
        <tbody>
            @foreach (var dept in Model)
            {
                <tr>
                    <td>@dept.DeptId</td>
                    <td>@dept.Name</td>
                    <td>@dept.Location.Replace("Campus", "").Trim()</td>
                    <td>@dept.PhoneNumber</td>
                    <td>@dept.Students.Count</td>
                    <td class="text-center">

                        <a asp-action="Details"
                           asp-route-id="@dept.DeptId"
                           class="btn btn-info btn-sm">
                            View
                        </a>

                        <a asp-action="Edit"
                           asp-route-id="@dept.DeptId"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>
                        <a asp-action="Delete"
                           asp-route-id="@dept.DeptId"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure?')">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>