@model StudentSystem.Models.Department

<div class="container mt-5 d-flex justify-content-center">
    <div class="card shadow-lg rounded-4 p-4" style="width:480px;">

        <h4 class="fw-bold text-center mb-3">🏢 @Model.Name</h4>

        <hr />

        <p class="mb-1"><b>ID:</b> @Model.DeptId</p>
        <p class="mb-1"><b>Location:</b> @Model.Location.Replace("Campus", "").Trim()</p>
        <p class="mb-1"><b>Phone:</b> @Model.PhoneNumber</p>
        <p class="mb-1"><b>Students Count:</b> @Model.Students.Count</p>


        <a asp-action="Index" class="btn btn-primary w-100 mt-3">Back</a>

    </div>
</div>