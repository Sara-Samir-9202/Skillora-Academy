@model StudentSystem.Models.Course

<div class="container mt-5 d-flex justify-content-center">
    <div class="card shadow-lg rounded-4 p-4" style="width:480px;">

        <h4 class="fw-bold text-center mb-3">📚 @Model.Name</h4>

        <hr />

        <p class="mb-1"><b>Description:</b> @Model.Description</p>
        <p class="mb-1"><b>Min Degree:</b> @Model.MinDegree</p>
        <p class="mb-1"><b>Max Degree:</b> @Model.MaxDegree</p>
        <p class="mb-1"><b>Students Enrolled:</b> @Model.StudentCourses.Count</p>


        <a asp-action="Index" class="btn btn-primary w-100 mt-3">Back</a>

    </div>
</div>