@model IEnumerable<StudentSystem.Models.Course>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">
        ➕ Add New Course
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover shadow-sm">

        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Description</th>
                <th>Min</th>
                <th>Max</th>
                <th>Students</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var course in Model)
            {
                <tr>
                    <td>@course.CrsId</td>
                    <td>@course.Name</td>
                    <td>@course.Description</td>
                    <td>@course.MinDegree</td>
                    <td>@course.MaxDegree</td>
                    <td>@(course.StudentCourses?.Count ?? 0)</td>

                    <td class="text-center">

                        <a asp-action="Details"
                           asp-route-id="@course.CrsId"
                           class="btn btn-info btn-sm">
                            View
                        </a>

                        <a asp-action="Edit" asp-route-id="@course.CrsId"
                           class="btn btn-warning btn-sm">Edit</a>

                        <a asp-action="Delete" asp-route-id="@course.CrsId"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure?')">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>
</div>