@model StudentSystem.ViewModels.StudentDetailsVM

<div class="container mt-5 d-flex justify-content-center">
    <div class="card shadow-lg rounded-4 p-4" style="width:380px;">

        <div class="profile-img mx-auto">
            <img src="/images/@Model.Image" />
        </div>

        <h3 class="mt-3 fw-bold text-center">@Model.Name</h3>

        <hr />

        <p class="mb-1"><b>Email:</b> @Model.Email</p>
        <p class="mb-1"><b>Address:</b> @Model.Address</p>
        <p class="mb-1"><b>Phone:</b> @Model.Phone</p>

        <hr />

        <p class="mb-1">
            <b>Department:</b>
            <span class="text-primary">@Model.DepartmentName</span>
        </p>

        <hr />

        <h5>Courses</h5>

        @if (Model.Courses != null && Model.Courses.Any())
        {
            foreach (var c in Model.Courses)
            {
                <p class="mb-0"><b>Course Name:</b> @c.CourseName</p>
                <p class="mb-2">
                    <b>Degree:</b>
                    <span style="color:@(c.Degree < 60 ? "red" : "green"); font-weight:bold;">
                        @c.Degree
                    </span>
                </p>
            }
        }

        <a asp-action="Index" class="btn btn-primary w-100 mt-3">
            Back
        </a>

    </div>
</div>

<style>
    .profile-img {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        overflow: hidden;
        border: 4px solid #0d6efd;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

        .profile-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
</style>